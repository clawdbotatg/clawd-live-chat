# clawd-live-chat config (gitignored as .clawd-live-chat.env — never commit real keys)
# Anything NOT set here falls back to ~/clawd-harness/.clawd-harness.env, so on a
# box with the harness configured you usually need NO env file at all.

# Fast brain — OpenAI-compatible gateway (Bankr)
#BANKR_API_KEY=...
#BANKR_BASE_URL=https://llm.bankr.bot/v1
#BANKR_API=bankr
#FAST_MODEL=claude-haiku-4-5-20251001
#FAST_MAX_TOKENS=700

# TTS — ElevenLabs Flash v2.5 (without a key the browser falls back to Web Speech)
#ELEVENLABS_API_KEY=...
#ELEVENLABS_VOICE_ID=...

# Phone-call mode — an overall agenda the agent steers the conversation toward
# (never spoken aloud; unset = no agenda, just chat)
#CALL_GOAL=Get the caller to agree to a demo of the product next week

# Phone line — Twilio voice (the agent answers/places real calls)
# Console: https://console.twilio.com — buy a number (~$1.15/mo), point its
# Voice webhook at $PUBLIC_URL/voice (POST). PUBLIC_URL = a tunnel to this
# server, e.g. `cloudflared tunnel --url http://localhost:8790` (free, no acct).
# CALLER_ID: a Twilio-verified personal number to show as outbound caller ID.
# Outbound: curl -X POST localhost:8790/call -d '{"to":"+19705551234"}'
#TWILIO_ACCOUNT_SID=AC...
#TWILIO_AUTH_TOKEN=...
#TWILIO_NUMBER=+1970...
#CALLER_ID=
#PUBLIC_URL=https://something.trycloudflare.com
#PHONE_VALIDATE=1

# Deep tier — claude-p-agent engine (claude -p on your subscription)
#CLAUDE_P_AGENT_HOME=../claude-p-agent
#DEEP_CWD=./deepwork
#DEEP_ARGS=--permission-mode acceptEdits
#DEEP_TIMEOUT=1800

# Dedicated names (a harness-spawned shell inherits PORT=8787 — don't use PORT)
#CHAT_PORT=8790
#CHAT_BIND=127.0.0.1
